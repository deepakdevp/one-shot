# =============================================================================
# One-Shot — Credentials Template
# =============================================================================
# Copy this file to ~/credentials.env (OUTSIDE any project folder), fill in
# your keys, and chmod 600 it. When Claude asks for credentials in Phase 0,
# paste from this file.
#
# NEVER commit a filled-in version of this file to a public repo.
# =============================================================================

# -----------------------------------------------------------------------------
# Database — Supabase (REQUIRED)
# -----------------------------------------------------------------------------
# Get from: https://supabase.com → Project Settings → API
DATABASE_URL=postgres://postgres.[ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Auth — Better-Auth (REQUIRED)
# -----------------------------------------------------------------------------
# Generate the secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Payments — Razorpay (REQUIRED for India)
# -----------------------------------------------------------------------------
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Webhook secret from: Settings → Webhooks → Add new
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Payments — Paddle (OPTIONAL — global Merchant of Record)
# -----------------------------------------------------------------------------
# Get from: https://vendors.paddle.com → Developer Tools → Authentication
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
# PADDLE_ENVIRONMENT=sandbox  # or production

# -----------------------------------------------------------------------------
# Payments — Stripe (ONLY if you have a US entity)
# -----------------------------------------------------------------------------
# Most Indian founders should use Razorpay + Paddle and skip Stripe.
# STRIPE_SECRET_KEY=sk_test_xxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Email — Resend (REQUIRED)
# -----------------------------------------------------------------------------
# Get from: https://resend.com → API Keys
# Verify your sending domain at: Domains → Add Domain
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=hello@yourdomain.com

# -----------------------------------------------------------------------------
# Analytics — PostHog (REQUIRED)
# -----------------------------------------------------------------------------
# Get from: https://app.posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# Errors — Sentry (REQUIRED)
# -----------------------------------------------------------------------------
# Get from: https://sentry.io → Project → Client Keys (DSN)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# -----------------------------------------------------------------------------
# Background Jobs — Inngest (REQUIRED)
# -----------------------------------------------------------------------------
# Get from: https://app.inngest.com → Apps → Create new app
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# -----------------------------------------------------------------------------
# Hosting — Vercel (REQUIRED for deploy)
# -----------------------------------------------------------------------------
# Vercel CLI handles auth — these are for CI/CD or programmatic deploys
# Get from: https://vercel.com/account/tokens
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=

# -----------------------------------------------------------------------------
# CDN/DNS — Cloudflare (OPTIONAL)
# -----------------------------------------------------------------------------
# Get from: https://dash.cloudflare.com → My Profile → API Tokens
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_ZONE_ID=

# -----------------------------------------------------------------------------
# AI Features — Anthropic / OpenAI (OPTIONAL — only if product has AI)
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=          # for Gemini / Nano Banana Pro image gen

# -----------------------------------------------------------------------------
# Caching — Upstash Redis (OPTIONAL)
# -----------------------------------------------------------------------------
# Get from: https://console.upstash.com
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Monitoring — BetterStack (OPTIONAL)
# -----------------------------------------------------------------------------
# BETTERSTACK_API_TOKEN=
# BETTERSTACK_STATUS_PAGE_ID=

# -----------------------------------------------------------------------------
# CMS — Sanity (OPTIONAL — for blog/docs)
# -----------------------------------------------------------------------------
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_API_TOKEN=

# -----------------------------------------------------------------------------
# Domain (REQUIRED before deploy)
# -----------------------------------------------------------------------------
# Not an env var — just a reminder. Buy at Namecheap / Cloudflare / Porkbun.
# DOMAIN_NAME=yourdomain.com

# -----------------------------------------------------------------------------
# India compliance (NOT secrets — but Claude asks in Phase 0)
# -----------------------------------------------------------------------------
# COMPANY_LEGAL_NAME=Your Company Pvt Ltd
# GSTIN=                    # 15-character GSTIN
# CIN=                      # Corporate Identification Number
# IEC_CODE=                 # Import Export Code from DGFT
# REGISTERED_ADDRESS=
# GRIEVANCE_OFFICER_NAME=
# GRIEVANCE_OFFICER_EMAIL=
# CERT_IN_POC_NAME=
# CERT_IN_POC_EMAIL=
